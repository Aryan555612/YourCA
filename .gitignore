# ── Flutter / Dart ─────────────────────────────────────────────────────────────
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
pubspec.lock

# ── Firebase (NEVER commit real credentials) ───────────────────────────────────
# Note: firebase_options.dart and google-services.json contain project config
# (not secrets). Security is enforced by Firestore Rules, not these files.
.firebase/
firebase-debug.log
firestore-debug.log

# ── Android ────────────────────────────────────────────────────────────────────
*.keystore
*.jks
*.b64.txt
android/key.properties
android/local.properties
android/.gradle/
android/captures/
android/gradlew
android/gradlew.bat

# ── iOS ────────────────────────────────────────────────────────────────────────
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Runner.xcworkspace/
*.xcworkspace
*.xcuserstate

# ── Web ────────────────────────────────────────────────────────────────────────
# (build/web/ is the deploy artifact — also excluded by build/)

# ── IDE ────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.iml

# ── Node (Cloud Functions) ─────────────────────────────────────────────────────
functions/node_modules/


rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User documents ─────────────────────────────────────────────────────
    // Each user can only read/write their own profile.
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      // ── Transactions sub-collection ──────────────────────────────────────
      // Only the owning user can read/write/delete their transactions.
      match /transactions/{txId} {
        allow read, write, delete: if request.auth != null
                                   && request.auth.uid == userId;

        // Validate transaction write data
        allow create: if request.auth != null
                      && request.auth.uid == userId
                      && request.resource.data.keys().hasAll([
                           'user_id', 'amount', 'type', 'category',
                           'merchant', 'date', 'source', 'created_at'
                         ])
                      && request.resource.data.amount is number
                      && request.resource.data.amount > 0
                      && request.resource.data.type in ['debit', 'credit']
                      && request.resource.data.source in [
                           'sms', 'manual', 'statement_import', 'aa'
                         ];
      }

      // ── Merchant corrections sub-collection ─────────────────────────────
      match /merchantCorrections/{merchantKey} {
        allow read, write, delete: if request.auth != null
                                   && request.auth.uid == userId;
      }
    }

    // ── OTP verification documents (Secure OTP verification by Document ID) ──
    match /otps/{otpDocId} {
      // Anyone can create and get (read single doc) to verify, but NO ONE can list/query the collection.
      allow create, get: if true;
      allow list, update: if false;
      // Anyone can delete the OTP doc (clean up can be done unauthenticated or after sign-in)
      allow delete: if true;
    }

    // ── Stable user ID mapping (email → consistent SQLite user_id) ──────────
    // Anyone can read their own stable ID (needed after reinstall).
    // First write creates the ID; subsequent writes update timestamp only.
    match /user_stable_ids/{email} {
      allow read: if true; // Public read so we can look up by email
      allow create: if true; // First-time creation (unauthenticated, before login)
      allow update: if request.auth != null; // Only update if logged in
    }

    // ── Firebase UID → Stable UID mapping (for future cloud sync) ───────────
    match /firebase_uid_map/{firebaseUid} {
      allow read, write: if request.auth != null
                         && request.auth.uid == firebaseUid;
    }

    // ── Brevo / App Config (read-only for authenticated users) ───────────────
    match /config/{configId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Deny all other access ─────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}


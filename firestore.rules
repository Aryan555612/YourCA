rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User documents ─────────────────────────────────────────────────────
    // Each user can only read/write their own profile.
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      // ── Transactions sub-collection ──────────────────────────────────────
      // Only the owning user can read/write/delete their transactions.
      match /transactions/{txId} {
        allow read, write, delete: if request.auth != null
                                   && request.auth.uid == userId;

        // Validate transaction write data
        allow create: if request.auth != null
                      && request.auth.uid == userId
                      && request.resource.data.keys().hasAll([
                           'user_id', 'amount', 'type', 'category',
                           'merchant', 'date', 'source', 'created_at'
                         ])
                      && request.resource.data.amount is number
                      && request.resource.data.amount > 0
                      && request.resource.data.type in ['debit', 'credit']
                      && request.resource.data.source in [
                           'sms', 'manual', 'statement_import', 'aa'
                         ];
      }

      // ── Merchant corrections sub-collection ─────────────────────────────
      match /merchantCorrections/{merchantKey} {
        allow read, write, delete: if request.auth != null
                                   && request.auth.uid == userId;
      }
    }

    // ── OTP verification documents (Secure Write-Only verification) ─────────
    match /otps/{email} {
      // Anyone can generate/create an OTP doc, but NO ONE can read or update it.
      allow create: if true;
      allow read, update: if false;
      // Only signed-in users can delete the OTP doc after successful login.
      allow delete: if request.auth != null;

      match /attempts/{attemptId} {
        // Verification attempt only succeeds if the entered code is correct and not expired.
        allow create: if request.resource.data.enteredCode == get(/databases/$(database)/documents/otps/$(email)).data.code
                      && request.time < timestamp(get(/databases/$(database)/documents/otps/$(email)).data.expires_at);
        allow read, update: if false;
        allow delete: if request.auth != null;
      }
    }

    // ── Stable user ID mapping (email → consistent SQLite user_id) ──────────
    // Anyone can read their own stable ID (needed after reinstall).
    // First write creates the ID; subsequent writes update timestamp only.
    match /user_stable_ids/{email} {
      allow read: if true; // Public read so we can look up by email
      allow create: if true; // First-time creation (unauthenticated, before login)
      allow update: if request.auth != null; // Only update if logged in
    }

    // ── Firebase UID → Stable UID mapping (for future cloud sync) ───────────
    match /firebase_uid_map/{firebaseUid} {
      allow read, write: if request.auth != null
                         && request.auth.uid == firebaseUid;
    }

    // ── Brevo / App Config (read-only for authenticated users) ───────────────
    match /config/{configId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Deny all other access ─────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

